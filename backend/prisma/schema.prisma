generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// Enums
//
enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  LOBBY
  ACTIVE
  PAUSED
  FINISHED
}



//
// Models
//

model User {
  id          Int           @id @default(autoincrement())
  username    String        @unique
  email       String        @unique
  password    String
  avatarUrl   String?
  gamesPlayed Int?
  highScore   Int?
  wins        Int?
  memberSince DateTime?
  createdAt DateTime      @default(now())
  role      Role          @default(USER)

  // Relations
  hostedMatches Match[]       @relation("HostedMatches")
  matchPlayers   MatchPlayer[]
  answers        Answer[]
}

model Match {
  id          Int           @id @default(autoincrement())
  title       String
  category    String
  difficulty  String?
  isPublic    Boolean       @default(true)
  maxPlayers  Int           @default(5)
  timeLimit   Int           @default(10) // seconds per question
  status      MatchStatus   @default(LOBBY)
  completed   Boolean       @default(false) // true only if all questions answered by all active players
  createdAt   DateTime      @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  // Relations
  hostId Int
  host   User          @relation("HostedMatches", fields: [hostId], references: [id])

  players   MatchPlayer[]
  questions MatchQuestion[]
  answers   Answer[]
}

model MatchPlayer {
  id        Int      @id @default(autoincrement())
  matchId   Int
  userId    Int
  joinedAt  DateTime @default(now())
  connected Boolean  @default(true)
  score     Int      @default(0)
  isReady   Boolean  @default(false)

  match     Match    @relation(fields: [matchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([matchId, userId]) // prevent duplicate joins
}

model Question {
  id         Int      @id @default(autoincrement())
  category   String
  difficulty String?
  question   String
  correct    String
  options    String[]  // store multiple choices

  // Relations
  matches   MatchQuestion[]
  answers   Answer[]
}

model MatchQuestion {
  id         Int      @id @default(autoincrement())
  matchId    Int
  questionId Int
  order      Int      // order in match (1st, 2nd, etc.)

  match      Match    @relation(fields: [matchId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([matchId, questionId])
}

model Answer {
  id         Int      @id @default(autoincrement())
  selected   String
  isCorrect  Boolean
  createdAt  DateTime @default(now())

  // Relations
  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  matchId    Int
  match      Match    @relation(fields: [matchId], references: [id])
}
